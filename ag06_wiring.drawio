                <mxCell id="c_atw" value="ATW-SP707a（Audio-Technica）&lt;br&gt;―――――――――&lt;br&gt;XLR入力①: XLRマイク①&lt;br&gt;XLR入力②: XLRマイク②&lt;br&gt;ワイヤレス受信（内蔵）&lt;br&gt;AUX入力: RCA赤白（Zoom返し音）&lt;br&gt;音声出力: 6.3mm TS → AG06 CH1&lt;br&gt;―――――――――&lt;br&gt;会場スピーカー（内蔵アンプ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="270" y="1045" width="220" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="c_ag06" value="AG06（YAMAHA）&lt;br&gt;―――――――――&lt;br&gt;CH1: 6.3mm TS（ATW音声出力）&lt;br&gt;CH2: 空き（未使用）&lt;br&gt;―――――――――&lt;br&gt;TO PC: DRY CH1/2&lt;br&gt;1-2CH MONITOR MUTE: ON&lt;br&gt;MONITOR OUT: 6.3mm TRS&lt;br&gt;ファンタム電源: OFF（重要）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="570" y="1045" width="240" height="250" as="geometry"/>
