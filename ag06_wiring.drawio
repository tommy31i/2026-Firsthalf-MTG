                <mxCell id="c_pc" value="PC / Zoom&lt;br&gt;（USB接続）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="870" y="1130" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_loop_note" value="✅ ループ断ち切り原理（パターンB環境でも有効）:&lt;br&gt;1-2CH MONITOR MUTE: ON により&lt;br&gt;CH1（ATW音声出力）がMONITOR OUTに出ない&lt;br&gt;→ MONITOR OUTにはZoom返し音のみ&lt;br&gt;→ ATW AUXに戻っても再ループしない ✓&lt;br&gt;※ AUX混ざりのわずかなエコーはZoom AECが処理" style="text;html=1;strokeColor=#b85450;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="570" y="1330" width="280" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="c_cable" value="必要なケーブル:&lt;br&gt;・XLRケーブル × 2（マイク→ATW）&lt;br&gt;・USBケーブル（AG06付属）&lt;br&gt;・6.3mm TS直挿し（ATW音声出力→AG06 CH1）&lt;br&gt;　※ TSはTRSジャックにそのまま挿せる（変換不要）&lt;br&gt;・6.3mm TRS(L/R)→RCA赤白 変換ケーブル" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="570" y="1460" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="c_zoom" value="Zoom音声設定（パターンC）:&lt;br&gt;・マイク → Yamaha AG06&lt;br&gt;　受信: ATW音声出力（XLRマイク①②&lt;br&gt;　＋ワイヤレスがATW経由でミックス）&lt;br&gt;　AG06: TO PC = DRY CH1/2&lt;br&gt;・スピーカー → Yamaha AG06" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="870" y="1045" width="270" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c_arr_mic1" value="XLRケーブル" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" parent="1" source="c_mic1" target="c_atw" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
